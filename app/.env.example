###############################################################################
# APP / ENVIRONMENT
###############################################################################
# Ambiente da aplicação:
# - dev  => desenvolvimento local
# - hml  => homologação/staging
# - prod => produção
APP_ENV=dev

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Express host (bind)
APP_HOST=127.0.0.1

# Express port
APP_PORT=8080

# Quantos proxies existem imediatamente na frente do Node/Express.
# Isso afeta req.ip (e portanto o rate-limit por IP).
# Exemplos:
# - 0 => app exposta diretamente (sem proxy)
# - 1 => Nginx/Traefik direto na frente do Node
# - 2 => Cloudflare -> Nginx -> Node
TRUST_PROXY=1

###############################################################################
# CORS
###############################################################################
# Origins extras permitidas para requests cross-origin com cookies.
# A allowlist principal do SaaS deve vir do banco de dados (ex.: domÃ­nios ativos do whitelabel).
# Use esta lista sÃ³ para overrides estÃ¡ticos, dev local ou backoffice fora do catÃ¡logo dinÃ¢mico.
#
# Use lista separada por vÃ­rgula.
# Exemplos:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
#
# Se ficar vazio, o backend ainda pode permitir origins resolvidas dinamicamente via banco.
# Requests sem header Origin continuam funcionando normalmente.
CORS_ALLOWED_ORIGINS=

# NecessÃ¡rio para auth baseada em cookie em requests cross-origin permitidas.
CORS_ALLOW_CREDENTIALS=true

# =========================
# APP PUBLIC URL (prefixo dos links)
# =========================
# Base URL pública do app (sem barra no final)
APP_PUBLIC_URL=http://127.0.0.1:8080

# Endpoint de confirmação (rota GET)
EMAIL_CONFIRM_CONFIRM_ENDPOINT=/confirm

# TTL do token (minutos)
EMAIL_CONFIRMATION_TTL_MINUTES=10

# Resend cooldown (segundos)
EMAIL_CONFIRMATION_RESEND_COOLDOWN_SECONDS=60

# Tamanho do token base62 (8..64 recomendado; default: 12)
EMAIL_CONFIRMATION_TOKEN_LEN=12

# Guardar request_ip "packed" em VARBINARY(16)
EMAIL_CONFIRM_STORE_IP_PACKED=true

# Token: validação de formato no endpoint /forward/confirm
EMAIL_CONFIRMATION_TOKEN_MIN_LEN=10
EMAIL_CONFIRMATION_TOKEN_MAX_LEN=24

# =========================
# SMTP (envio de e-mail)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# Se seu SMTP não exigir auth, você pode desabilitar
SMTP_AUTH_ENABLED=true
SMTP_USER=
SMTP_PASS=

# "From" que aparece no e-mail
SMTP_FROM="John Doe <john.doe@ccc.de>"

# (opcional) nome HELO/EHLO
SMTP_HELO_NAME=

# TLS (true recomendado; em dev você pode colocar false pra self-signed)
SMTP_TLS_REJECT_UNAUTHORIZED=true

# (opcional) action padronizada para subject.
# O formato final fica: "{code} is your verification code | {host} / {action}"
# Você pode usar texto puro (ex.: alias:verify) ou um template completo com {code}/{host}.
EMAIL_CONFIRMATION_SUBJECT="alias:verify"

###############################################################################
# MARIADB (AUTH + CONNECTION)
###############################################################################
# Host do MariaDB (ex.: localhost, mariadb, 127.0.0.1)
MARIADB_HOST=

# Porta padrão do MariaDB
MARIADB_PORT=

# Usuário do MariaDB
MARIADB_USER=

# Senha do usuário do MariaDB
MARIADB_PASSWORD=

# Nome do banco de dados
MARIADB_DATABASE=

# (Opcional) Se você usa TLS/SSL no MariaDB:
# MARIADB_SSL=true
# MARIADB_SSL_CA_PATH=/path/to/ca.pem


###############################################################################
# REDIS (RATE LIMIT STORE - OPTIONAL)
###############################################################################
# Se REDIS_URL estiver vazio/não definido, o rate-limit usa MemoryStore (por instância).
# Para produção (multi-instância), recomendo habilitar.
#
# Exemplos:
# REDIS_URL=redis://:SENHA@127.0.0.1:6379/0
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=

# (Opcional) Prefixo para as chaves do rate-limit no Redis
# Ajuda a organizar e evitar colisões com outras apps.
REDIS_RATE_LIMIT_PREFIX=rl:

# (Opcional) Timeout de conexão com Redis em ms
REDIS_CONNECT_TIMEOUT_MS=5000


###############################################################################
# CHECKDNS RELAY (DNS VALIDATION SERVICE)
###############################################################################
# Base URL do serviço check-dns (sem barra no final)
CHECKDNS_BASE_URL=http://localhost:3000

# Token enviado como header x-api-key
CHECKDNS_TOKEN=

# Timeout HTTP em ms (default: 8000)
CHECKDNS_HTTP_TIMEOUT_MS=8000


###############################################################################
# RATE LIMIT / SLOW DOWN (DEFAULTS)
# Esses valores alimentam diretamente o rate_limit.js via process.env
###############################################################################

# Global: limite genérico por IP para toda a aplicação
RL_GLOBAL_PER_MIN=300

# -----------------------------
# /forward/subscribe (request)
# -----------------------------

# Slow Down por IP: começa a atrasar após X req/min
SD_SUBSCRIBE_DELAY_AFTER=10

# Slow Down step: quanto aumenta o atraso por request acima do "delayAfter"
SD_SUBSCRIBE_DELAY_STEP_MS=250

# Hard Limit por IP: N requests por 10 minutos
RL_SUBSCRIBE_PER_10MIN_PER_IP=60

# Hard Limit por destino (to=...): N requests por hora por email destino
RL_SUBSCRIBE_PER_HOUR_PER_TO=6

# Hard Limit por alias (domain+name): N requests por hora por alias
RL_SUBSCRIBE_PER_HOUR_PER_ALIAS=20

# -----------------------------
# /forward/confirm (confirm)
# -----------------------------

# Confirm Hard Limit por IP: N requests por 10 min
RL_CONFIRM_PER_10MIN_PER_IP=120

# Confirm Hard Limit por token: N requests por 10 min por token
RL_CONFIRM_PER_10MIN_PER_TOKEN=10

# -----------------------------
# /forward/unsubscribe (request)
# -----------------------------

# Slow Down por IP no unsubscribe request
SD_UNSUBSCRIBE_DELAY_AFTER=8
SD_UNSUBSCRIBE_DELAY_STEP_MS=300

# Hard Limit por IP no unsubscribe request
RL_UNSUBSCRIBE_PER_10MIN_PER_IP=40

# Hard Limit por address (alias address): N requests por hora por address
RL_UNSUBSCRIBE_PER_HOUR_PER_ADDRESS=6

# -----------------------------
# /forward/unsubscribe/confirm
# -----------------------------

# Confirm Hard Limit por IP no unsubscribe confirm
RL_UNSUBSCRIBE_CONFIRM_PER_10MIN_PER_IP=120

# Confirm Hard Limit por token no unsubscribe confirm
RL_UNSUBSCRIBE_CONFIRM_PER_10MIN_PER_TOKEN=10

# Domínio padrão usado quando o usuário NÃO informa ?domain=
DEFAULT_ALIAS_DOMAIN=thc.org

# TTL do link/token de confirmação (minutos)
EMAIL_CONFIRMATION_TTL_MINUTES=10

EMAIL_CONFIRMATION_SUBJECT_SUBSCRIBE="alias:create"
EMAIL_CONFIRMATION_SUBJECT_UNSUBSCRIBE="alias:delete"

# -----------------------------
# /api/checkdns/:target
# -----------------------------
# Por target: N requests por 10 min
RL_CHECKDNS_PER_10MIN_PER_TARGET=30

# -----------------------------
# /request/ui
# -----------------------------
# Por IP: N requests por minuto
RL_REQUEST_UI_PER_MIN_PER_IP=60
# Por target: N requests por 10 min
RL_REQUEST_UI_PER_10MIN_PER_TARGET=20

# -----------------------------
# /request/email
# -----------------------------
# Por IP: N requests por 10 min
RL_REQUEST_EMAIL_PER_10MIN_PER_IP=20
# Por target: N requests por hora
RL_REQUEST_EMAIL_PER_HOUR_PER_TARGET=3

# -----------------------------
# /api/credentials/create
# -----------------------------
# Por IP: N requests por hora
RL_CREDENTIALS_CREATE_PER_HOUR_PER_IP=10
# Por email: N requests por hora
RL_CREDENTIALS_CREATE_PER_HOUR_PER_EMAIL=3

# -----------------------------
# /api/credentials/confirm
# -----------------------------
# Por IP: N requests por 10 min
RL_CREDENTIALS_CONFIRM_PER_10MIN_PER_IP=60
# Por token: N requests por 10 min
RL_CREDENTIALS_CONFIRM_PER_10MIN_PER_TOKEN=5

# -----------------------------
# /auth/register
# -----------------------------
# Por IP: N cadastros por hora
RL_AUTH_REGISTER_PER_HOUR_PER_IP=10
# Por email: N cadastros por hora
RL_AUTH_REGISTER_PER_HOUR_PER_EMAIL=3
# Por IP: N confirmaÃ§Ãµes por 10 min
RL_AUTH_REGISTER_CONFIRM_PER_10MIN_PER_IP=30
# Por token: N confirmaÃ§Ãµes por 10 min
RL_AUTH_REGISTER_CONFIRM_PER_10MIN_PER_TOKEN=10

# -----------------------------
# /auth/password/forgot
# -----------------------------
# Por IP: N pedidos por hora
RL_AUTH_PASSWORD_RESET_REQUEST_PER_HOUR_PER_IP=10
# Por email: N pedidos por hora
RL_AUTH_PASSWORD_RESET_REQUEST_PER_HOUR_PER_EMAIL=3

# -----------------------------
# /auth/login (failed attempts only)
# -----------------------------
# Por IP: N falhas por 15 min
RL_ADMIN_LOGIN_FAIL_PER_15MIN_PER_IP=12
# Por email: N falhas por hora
RL_ADMIN_LOGIN_FAIL_PER_HOUR_PER_EMAIL=6
# Por combinação email+IP: N falhas por 6 horas (punição pesada)
RL_ADMIN_LOGIN_FAIL_PER_6H_PER_EMAIL_IP=3
# Por combinação email+IP: N falhas por 5 min (detecção rápida)
RL_ADMIN_LOGIN_FAIL_PER_5MIN_PER_EMAIL_IP=2

# -----------------------------
# /auth/password/reset
# -----------------------------
# Por IP: N tentativas por 10 min
RL_AUTH_PASSWORD_RESET_CONFIRM_PER_10MIN_PER_IP=30
# Por token: N tentativas por 10 min
RL_AUTH_PASSWORD_RESET_CONFIRM_PER_10MIN_PER_TOKEN=10

# -----------------------------
# /api/alias/* (authenticated)
# -----------------------------
# /api/alias/list - por API key
RL_ALIAS_LIST_PER_MIN_PER_KEY=600
# /api/alias/create - por API key
RL_ALIAS_CREATE_PER_MIN_PER_KEY=120
# /api/alias/delete - por API key
RL_ALIAS_DELETE_PER_MIN_PER_KEY=120

###############################################################################
# API CREDENTIALS EMAIL
###############################################################################
API_CREDENTIALS_CONFIRM_ENDPOINT=/api/credentials/confirm
API_CREDENTIALS_EMAIL_TTL_MINUTES=15
API_CREDENTIALS_EMAIL_RESEND_COOLDOWN_SECONDS=60
API_CREDENTIALS_EMAIL_TOKEN_LEN=20
API_CREDENTIALS_EMAIL_SUBJECT="api-key:create"

###############################################################################
# AUTH REGISTER EMAIL
###############################################################################
AUTH_REGISTER_CONFIRM_ENDPOINT=/auth/register/confirm
AUTH_REGISTER_TTL_MINUTES=15
AUTH_REGISTER_RESEND_COOLDOWN_SECONDS=60
AUTH_REGISTER_MAX_SENDS=3
AUTH_REGISTER_EMAIL_SUBJECT="Verify your email"

###############################################################################
# PASSWORD RESET EMAIL
###############################################################################
PASSWORD_RESET_TTL_MINUTES=15
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_SENDS=3
PASSWORD_RESET_EMAIL_SUBJECT="Password reset"

###############################################################################
# BROWSER AUTH / JWT / CSRF
###############################################################################
# Segredo do token CSRF por famÃ­lia de sessÃ£o.
AUTH_CSRF_SECRET=change-me

# SessÃ£o de refresh
AUTH_REFRESH_TTL_DAYS=30
AUTH_MAX_ACTIVE_SESSION_FAMILIES=5

# Endpoint usado no email de verificaÃ§Ã£o
AUTH_VERIFY_EMAIL_ENDPOINT=/auth/verify-email

# JWT de acesso (Ed25519 / EdDSA)
JWT_ACCESS_KID=access-key-1

# PEM com \n escapado ou string multilinha, dependendo do seu loader.
JWT_ACCESS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<replace-me>\n-----END PRIVATE KEY-----"

# JSON por kid. Precisa conter a chave pÃºblica do kid ativo acima.
JWT_ACCESS_VERIFY_KEYS={"access-key-1":"-----BEGIN PUBLIC KEY-----\n<replace-me>\n-----END PUBLIC KEY-----"}

JWT_ACCESS_ISSUER=mail-forwarding-api
JWT_ACCESS_AUDIENCE=mail-forwarding-web
JWT_ACCESS_TTL_SECONDS=600
JWT_ACCESS_CLOCK_SKEW_SECONDS=60

###############################################################################
# ADMIN AUTH (NO SELF-REGISTER)
###############################################################################
# Sessão de autenticação admin (retorno de /admin/login)
ADMIN_AUTH_SESSION_TTL_MINUTES=720
ADMIN_AUTH_TOKEN_BYTES=32

# Hash dummy para reduzir diferença de tempo quando email não existe.
# Pode deixar vazio para usar fallback interno.
ADMIN_AUTH_DUMMY_PASSWORD_HASH=

# Argon2id para hash de senha admin (custos altos + salt único por usuário)
ADMIN_AUTH_ARGON2_TIME_COST=4
ADMIN_AUTH_ARGON2_MEMORY_COST=131072
ADMIN_AUTH_ARGON2_PARALLELISM=1
ADMIN_AUTH_ARGON2_HASH_LENGTH=32
ADMIN_AUTH_ARGON2_SALT_LENGTH=16

# Notificação por e-mail em todo login admin bem-sucedido
ADMIN_LOGIN_EMAIL_ENABLED=true
ADMIN_LOGIN_EMAIL_SUBJECT="Security alert: admin login | {host}"

# Notificação por e-mail para mudanças em usuários admin (create/update/delete/password)
ADMIN_USER_CHANGE_EMAIL_ENABLED=true
ADMIN_USER_CHANGE_EMAIL_SUBJECT="Security alert: admin account changed | {host}"
